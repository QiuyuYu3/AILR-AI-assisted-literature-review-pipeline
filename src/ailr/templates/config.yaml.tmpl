# {{project_name}} - ailr review configuration.
# Generated by `ailr init`. Edit freely; missing fields fall back to mode preset,
# then to package defaults.

project:
  name: {{project_name}}
  type: scoping              # scoping | systematic | methodological_scoping
  description: ""
  mode: {{mode}}             # strict | assisted | custom
  mode_preset: null          # optional path to a user-defined preset YAML

# Top-level LLM defaults. Per-stage overrides below.
llm:
  provider: anthropic        # anthropic | openai | gemini
  model: claude-sonnet-4-6
  temperature: 0
  seed: 42
  max_retries: 3

screening:
  prompt: prompts/screening.txt
  criteria: inclusion_criteria.md
  batch_size: 20
  llm:                       # cheaper model for abstract screening
    model: claude-haiku-4-5-20251001
  # workflow: assisted | independent
  #   assisted   = AI + 1 human, both blinded
  #   independent = 2 humans, AI optional reference (--include-ai to run)
  # target_kappa, calibration inherit from mode preset unless overridden here

extraction:
  prompt: prompts/extraction.txt
  schema_path: schema.yaml
  codebook: codebook.yaml    # set to null to disable emergent codebook
  chunk_strategy: full       # full | methods_only | custom
  # workflow: verify | independent
  #   verify     = AI extracts, human verifies/edits (PI-recommended)
  #   independent = human extracts blind, AI hidden until submit
  # output_format, flag_check, target_kappa, calibration inherit from mode preset
  llm:                       # stronger model for full-text extraction
    model: claude-sonnet-4-6

preprocess:
  pdf_backend: pymupdf       # pymupdf | marker | grobid
  strip_references: true
  keep_sections: []

storage:
  database: data/review.sqlite   # local SQLite, used when database_url is blank
  # database_url: ""             # set to a Postgres URL to share with a team (paste as-is), e.g.
  #   "postgresql://user:pw@host/db?sslmode=require"
  # Holds the DB password -> do not commit this file to a public git repo (see .gitignore).

logging:
  level: INFO
  audit_log: data/audit.jsonl
